{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telegramonly.local/schema/apix-profile-v2.schema.json",
  "title": "apix-profile v2",
  "description": "Policy-aware ApiX profile with Telegram-only routing support.",
  "type": "object",
  "required": [
    "format",
    "version",
    "source",
    "profile",
    "server",
    "vpn_mode",
    "routing_policy"
  ],
  "properties": {
    "format": {
      "type": "string",
      "const": "apix-profile"
    },
    "version": {
      "type": "integer",
      "const": 2
    },
    "source": {
      "type": "object",
      "required": [
        "app",
        "exported_at"
      ],
      "properties": {
        "app": {
          "type": "string"
        },
        "exported_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": [
        "id",
        "name",
        "icon",
        "color",
        "protocol_type",
        "is_default"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "protocol_type": {
          "type": "string",
          "enum": [
            "reality",
            "hysteria2",
            "tuic",
            "anytls",
            "xhttp"
          ]
        },
        "is_default": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "server": {
      "type": "object",
      "required": [
        "host",
        "port"
      ],
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": false
    },
    "vpn_mode": {
      "type": "string",
      "enum": [
        "auto",
        "tun",
        "socks5"
      ]
    },
    "reality": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "uuid": {
          "type": "string"
        },
        "public_key": {
          "type": "string"
        },
        "short_id": {
          "type": "string"
        },
        "sni": {
          "type": "string"
        },
        "fingerprint": {
          "type": "string"
        },
        "flow": {
          "type": "string"
        },
        "network": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "hysteria2": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "password": {
          "type": "string"
        },
        "sni": {
          "type": "string"
        },
        "insecure": {
          "type": "boolean"
        },
        "up_mbps": {
          "type": "integer",
          "minimum": 0
        },
        "down_mbps": {
          "type": "integer",
          "minimum": 0
        },
        "obfs_type": {
          "type": "string"
        },
        "obfs_password": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "routing_policy": {
      "type": "object",
      "required": [
        "enabled",
        "mode",
        "transport_candidates",
        "client_targets",
        "fallback_transport",
        "fail_mode",
        "telegram_domains",
        "telegram_ip_cidrs"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "const": "telegram_only"
        },
        "transport_candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "reality",
              "hysteria2",
              "tuic",
              "anytls",
              "xhttp"
            ]
          }
        },
        "client_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "apixgrpc",
              "sing-box",
              "clash-meta"
            ]
          }
        },
        "fallback_transport": {
          "type": "string",
          "enum": [
            "none",
            "mtproto"
          ]
        },
        "fail_mode": {
          "type": "string",
          "enum": [
            "fail_open",
            "fail_closed"
          ]
        },
        "telegram_domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "telegram_ip_cidrs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "properties": {
        "subscription_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "server_label": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "properties": {
              "protocol_type": {
                "const": "reality"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "reality"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "profile": {
            "properties": {
              "protocol_type": {
                "const": "hysteria2"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "hysteria2"
        ]
      }
    }
  ],
  "additionalProperties": false
}
