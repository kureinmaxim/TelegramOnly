# ============================================================
# TelegramSimple Environment Configuration
# ============================================================
# ВНИМАНИЕ: Скопируйте этот файл в .env и заполните значения!
# НИКОГДА не коммитьте .env файл в Git!
# ============================================================

# === TELEGRAM BOT ===
BOT_TOKEN=your_telegram_bot_token_here

# === ADMINISTRATORS ===
# Telegram ID администраторов (через запятую)
# Узнать свой ID: отправьте /info боту
ADMIN_USER_IDS=123456789

# === AI PROVIDERS ===
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI GPT API
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o

# Default provider (anthropic или openai)
DEFAULT_AI_PROVIDER=anthropic

# === API SECURITY ===
# Основной API ключ (минимум 32 символа!)
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=your_very_long_random_secret_key_here_64_chars_minimum

# URL API (команда /api покажет это значение)
# Замените YOUR_SERVER_IP на IP вашего сервера
API_URL=http://YOUR_SERVER_IP:8000/ai_query

# HMAC секрет для подписи запросов (минимум 32 символа!)
# Генерация: openssl rand -hex 32
HMAC_SECRET=another_random_secret_for_hmac_signing_also_64_chars

# Ключ шифрования (AES-256). Если не задан, используется API_SECRET_KEY.
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=optional_separate_encryption_key_otherwise_api_secret_is_used

# === SECURITY SETTINGS ===
# Включение проверок безопасности (true/false)
ENABLE_SIGNATURE_CHECK=true
ENABLE_TIMESTAMP_CHECK=true
ENABLE_NONCE_CHECK=true
ENABLE_RATE_LIMITING=true
ENABLE_APP_WHITELIST=true

# Время жизни timestamp в секундах (по умолчанию 300 = 5 минут)
TIMESTAMP_TOLERANCE=300

# === ALLOWED APPLICATIONS ===
# Список разрешённых APP_ID через запятую
ALLOWED_APP_IDS=bomcategorizer-v5,apiai-v2,apiai-v3,test-client

# === RATE LIMITING ===
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# === LOGGING ===
LOG_LEVEL=INFO
# LOG_FILE=/var/log/telegramhelper/api.log

# === OPTIONAL: IP WHITELIST ===
# Список разрешённых IP через запятую (оставьте пустым для разрешения всех)
# ALLOWED_IPS=192.168.1.100,10.0.0.50

# === HYSTERIA2 VPN ===
# Путь к файлу конфигурации Hysteria2 (по умолчанию hysteria2_config.json)
HYSTERIA2_CONFIG_PATH=hysteria2_config.json
# Включить Hysteria2 (true/false)
HYSTERIA2_ENABLED=false

# === MTPROTO PROXY ===
# Путь к файлу конфигурации MTProto proxy (по умолчанию mtproto_config.json)
MTPROTO_CONFIG_PATH=mtproto_config.json
# Включить MTProto proxy (true/false)
MTPROTO_ENABLED=false

# === OPTIONAL: REDIS (для production) ===
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# ИНСТРУКЦИИ ПО ГЕНЕРАЦИИ БЕЗОПАСНЫХ КЛЮЧЕЙ:
# ============================================================
# 
# 1. Генерация API_SECRET_KEY:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
#
# 2. Генерация HMAC_SECRET:
#    openssl rand -hex 32
#
# 3. Получение Anthropic API ключа:
#    https://console.anthropic.com/
#
# 4. Получение OpenAI API ключа:
#    https://platform.openai.com/api-keys
#
# 5. Создание Telegram Bot:
#    Напишите @BotFather в Telegram
#
# ============================================================
